# Copy to `.env` in `backend/` (FastAPI reads env from CWD when launched from backend folder).
#
# Run the backend natively on macOS for Finder, Spotlight, and real filesystem tools.
# Docker is for optional services (e.g. Ollama); see README — do not rely on container-local storage for "your Mac."

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Prefer a non-reasoning chat model (e.g. llama3.2). Reasoning models (deepseek-r1) often need stripping.
OLLAMA_MODEL=llama3.2:latest

# Filesystem sandbox: comma-separated absolute roots (defaults: home, repo, cwd).
# Keyword search (Spotlight + walk) only sees files under these roots.
# Widen so Jarvis can list/search more paths:
# JARVIS_ALLOWED_ROOTS=/Users/you,/Users/you/Documents,/Volumes/External

# Modular macOS Finder + HUD match list (opt-in; not related to JARVIS_ALLOWED_ROOTS).
# JARVIS_MAC_FINDER_PRESET=recommended
# JARVIS_MAC_FINDER_ROOTS=/Users/you/Work,/custom/folder

# Terminal: comma-separated command prefixes allowed for `run_terminal`
# JARVIS_TERMINAL_ALLOW_PREFIXES=ls,git status,git diff,pwd,echo

# Speech — tiny = faster CPU STT; use base/small for accuracy
JARVIS_WHISPER_MODEL_SIZE=tiny
JARVIS_WHISPER_DEVICE=auto

# macos_say (ships on macOS), coqui (XTTS), cli_rvc (post-process), none
# Browser speaks replies immediately when true (recommended for latency).
JARVIS_VOICE_CLIENT_TTS=true
JARVIS_TTS_ENGINE=macos_say

# Optional ElevenLabs fallback (only wire in `app/voice/tts.py` if needed)
# ELEVENLABS_API_KEY=

# Wake word string match (utterances also checked client-side / after STT)
JARVIS_WAKE_WORD=jarvis

# open/show in Finder: auto = delegate when API is in Docker or not on macOS (browser → local bridge).
# client = always delegate | server = API runs `/usr/bin/open` (bare macOS API only).
# On your Mac: run uvicorn from Terminal/Cursor (not Docker) and prefer native open:
# JARVIS_FILE_ACTIONS_MODE=server
# JARVIS_FILE_ACTIONS_MODE=auto
# JARVIS_FORCE_CLIENT_FILE_ACTIONS=1
#
# On your Mac (when API is remote/Docker), run: python3 scripts/jarvis_file_bridge.py
# Frontend (.env.local): NEXT_PUBLIC_FILE_BRIDGE_URL=http://127.0.0.1:17834

# Optional RVC CLI + weights for cinematic voice polish
# JARVIS_RVC_CLI_PATH=/path/to/rvc/infer_cli
# JARVIS_RVC_MODEL_PATH=/path/to/jarvis.pth
# JARVIS_RVC_INDEX_PATH=/path/to/jarvis.index
